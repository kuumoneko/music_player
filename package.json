{
    "name": "music-player",
    "private": true,
    "type": "module",
    "version": "5.0.0-alpha",
    "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
    "author": {
        "name": "kuumoneko",
        "url": "https://github.com/kuumoneko"
    },
    "scripts": {
        "dev": "bun run build && electrobun dev",
        "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
        "hmr": "vite --port 5173",
        "build": "vite build && electrobun build",
        "build:prod": "vite build && electrobun buil",
        "start": "bun run dev"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.0",
        "@xhayper/discord-rpc": "^1.3.0",
        "bufferutil": "^4.1.0",
        "dotenv": "^17.3.1",
        "electrobun": "^1.13.1",
        "express": "^5.2.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.0",
        "utf-8-validate": "^6.0.6"
    },
    "devDependencies": {
        "7zip-min": "^2.1.0",
        "@fortawesome/free-brands-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/react-fontawesome": "^3.2.0",
        "@types/bun": "^1.3.9",
        "@types/discord-rpc": "^4.0.10",
        "@types/dotenv": "^8.2.3",
        "@types/node": "^25.3.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "autoprefixer": "^10.4.24",
        "concurrently": "^9.2.1",
        "postcss": "^8.5.6",
        "rcedit": "^5.0.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
