{
    "name": "music-player",
    "private": true,
    "version": "5.0.0-alpha",
    "description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
    "author": {
        "name": "kuumoneko",
        "url": "https://github.com/kuumoneko"
    },
    "scripts": {
        "dev": "bun run build && electrobun dev",
        "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
        "hmr": "vite --port 5173",
        "build": "vite build && electrobun build",
        "build:prod": "vite build && electrobun build --channel prod",
        "start": "bun run dev"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.1.17",
        "@xhayper/discord-rpc": "^1.1.8",
        "bufferutil": "^4.1.0",
        "dotenv": "^17.3.1",
        "electrobun": "1.13.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tailwindcss": "^4.1.17",
        "utf-8-validate": "^6.0.6"
    },
    "devDependencies": {
        "@fortawesome/free-brands-svg-icons": "^7.1.0",
        "@fortawesome/free-solid-svg-icons": "^7.1.0",
        "@fortawesome/react-fontawesome": "^3.1.0",
        "@types/discord-rpc": "^4.0.10",
        "@types/dotenv": "^6.1.1",
        "@types/node": "^24.10.1",
        "@types/bun": "latest",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.1.0",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.16",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.2",
        "vite": "^6.0.3",
        "7zip-min": "^2.1.0"
    }
}
